/*
 * nf-core/scdownstream configuration for integration and clustering
 * Input: QC-normalized h5ad from step 1
 * Output: Clustered h5ad with embeddings
 */

params {
    // Input: output from step 1 (QC + normalization)
    input = '/input/qc_normalized.h5ad'
    
    // Output directory
    outdir = '/output/scdownstream'
    
    // Integration method (single sample, so skip batch correction)
    integration = 'none'
    
    // Dimensionality reduction
    pca_dims = 50
    
    // Clustering parameters
    cluster_algorithm = 'leiden'
    resolution = 1.0
    
    // UMAP
    umap = true
    
    // Resource limits
    max_memory = '32.GB'
    max_cpus = 8
    max_time = '12.h'
}

// Use local executor
process {
    executor = 'local'
}

// Singularity for nf-core
singularity {
    enabled = true
    autoMounts = true
    cacheDir = '/home/khyeonmin/.singularity/cache'
}